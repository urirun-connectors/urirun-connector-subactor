{
  "id": "subactor",
  "name": "Subactor Service Processes",
  "status": "stable",
  "category": "Business Operations",
  "summary": "Server-side adapters for URI processes implemented by Subactor services.",
  "description": "Connects a urirun node to deployment-controlled Subactor service URLs. Hosts and bearer tokens come only from environment configuration, never from actor payloads.",
  "useCases": ["Static site generation", "Organization read models", "Schema-validated recruitment form drafts", "Contractor, project, TestQL and support service dispatch"],
  "requires": ["python>=3.10"],
  "install": {"mode": "pip", "pipSpec": "git+https://github.com/urirun-connectors/urirun-connector-subactor.git"},
  "provenance": "official",
  "publisher": {"name": "urirun-connectors", "url": "https://github.com/urirun-connectors"},
  "docsUrl": "https://github.com/urirun-connectors/urirun-connector-subactor",
  "language": "python",
  "uriSchemes": ["analytics", "contractor", "docs", "mail", "org", "organization", "project", "site-generator", "social", "support", "test", "testql", "webpage"],
  "adapterKinds": ["local-function"],
  "routes": [
    "analytics://host/doctor/query/report",
    "analytics://host/process/command/dispatch",
    "contractor://host/doctor/query/report",
    "contractor://host/process/command/dispatch",
    "docs://host/doctor/query/report",
    "docs://host/process/command/dispatch",
    "mail://host/doctor/query/report",
    "mail://host/process/command/dispatch",
    "org://host/doctor/query/report",
    "org://host/process/command/dispatch",
    "organization://host/doctor/query/report",
    "organization://host/process/command/dispatch",
    "organization://host/status/query",
    "organization://org-demo/status/query",
    "project://host/doctor/query/report",
    "project://host/process/command/dispatch",
    "site-generator://host/doctor/query/report",
    "site-generator://host/process/command/dispatch",
    "site-generator://host/site/command/generate",
    "social://host/doctor/query/report",
    "social://host/process/command/dispatch",
    "support://host/doctor/query/report",
    "support://host/process/command/dispatch",
    "test://host/doctor/query/report",
    "test://host/process/command/dispatch",
    "testql://host/doctor/query/report",
    "testql://host/process/command/dispatch",
    "webpage://host/doctor/query/report",
    "webpage://host/process/command/dispatch"
  ],
  "keywords": ["subactor", "soa", "business-process", "site-generator", "testql", "urirun"]
}
